# Copy this file to .env and fill in your values. .env is gitignored; never commit secrets.
# Cloud and local providers (including Azure) are configured through Settings, not the environment.

# Application data directory: where the SQLite DB and logs live. Default: ./userdata.
# Flag --data-dir takes precedence over this.
ANVIKA_DATA_DIR=./userdata

# TCP port to listen on. Default: 7800. Flag --port takes precedence over this.
ANVIKA_PORT=7800

# Development only: when true, allow prompt/response content into logs. Default: false. Never enable in production.
ANVIKA_LOG_CONTENT=false
